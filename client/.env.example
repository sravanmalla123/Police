# ============================================================
# AP Police Portal — Frontend Environment Variables
# ============================================================
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in your backend URL
# 3. NEVER commit .env.local to git
# ============================================================

# Development: points to local Express server
VITE_API_URL=http://localhost:4000/api

# Production (set this in Vercel Dashboard under Environment Variables):
# VITE_API_URL=https://your-backend-name.onrender.com/api
