# ============================================================
# AP Police Portal — Backend Environment Variables
# ============================================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in ALL values below
# 3. NEVER commit .env to git
# ============================================================

# ── Server ────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── JWT Authentication ────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING
JWT_EXPIRES_IN=1d

# ── CORS (comma-separated list of allowed frontend origins) ─
# Development:
CLIENT_URL=http://localhost:5173
# Production example:
# CLIENT_URL=https://your-app.vercel.app

# ── MySQL Database (Railway) ──────────────────────────────
MYSQLHOST=your-railway-host.railway.app
MYSQLPORT=3306
MYSQLUSER=root
MYSQLPASSWORD=your-railway-db-password
MYSQLDATABASE=police_portal

# ── Seed Passwords (required on first boot to create accounts) ─
# Use STRONG passwords — change immediately after first login!
SEED_ADMIN_PASSWORD=ChangeMe@Commissioner2026!
SEED_PASSWORD_CI=ChangeMe@CI2026!
SEED_PASSWORD_SI=ChangeMe@SI2026!
SEED_PASSWORD_CONST=ChangeMe@Const2026!
SEED_PASSWORD_STAFF=ChangeMe@Staff2026!

# ── Translation API (optional — falls back to Google free API) ─
# TRANSLATE_API_URL=https://your-libretranslate-instance.com/translate
